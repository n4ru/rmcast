diff --git a/src/libvncclient/rfbclient.c b/src/libvncclient/rfbclient.c
index f6baf641..78d72397 100644
--- a/src/libvncclient/rfbclient.c
+++ b/src/libvncclient/rfbclient.c
@@ -1335,6 +1335,11 @@ SetFormatAndEncodings(rfbClient* client)
 	encs[se->nEncodings++] = rfbClientSwap32IfLE(rfbEncodingCoRRE);
       } else if (strncasecmp(encStr,"rre",encStrLen) == 0) {
 	encs[se->nEncodings++] = rfbClientSwap32IfLE(rfbEncodingRRE);
+      } else if (strncasecmp(encStr,"rcastmono1",encStrLen) == 0) {
+	/* rcast-host private 1-bit mono pseudo-encoding (id -789).
+	 * Decoded inline by HandleRFBServerMessage as a luma threshold byte
+	 * followed by ceil(w/8)*h packed bits, MSB = leftmost pixel. */
+	encs[se->nEncodings++] = rfbClientSwap32IfLE(0xFFFFFCEB); /* -789 */
       } else {
 	rfbClientLog("Unknown encoding '%.*s'\n",encStrLen,encStr);
       }
@@ -2272,6 +2277,55 @@ HandleRFBServerMessage(rfbClient* client)
         client->SoftCursorLockArea(client, rect.r.x, rect.r.y, rect.r.w, rect.r.h);
       }
 
+      /* rcast-host private 1-bit mono encoding (id -789, 0xFFFFFCEB).
+       * Handled with a "do mono1, then jump past the switch to the
+       * common post-rect cleanup (SoftCursorUnlockScreen +
+       * GotFrameBufferUpdate)" pattern. We can't add it as a switch
+       * case here without a giant refactor and we MUST hit the cleanup
+       * — without GotFrameBufferUpdate firing, vnsee's commit_updates
+       * never sees the rect and the next IncrementalFBUR is never sent. */
+      if ((int32_t)rect.encoding == -789) {
+        int row_bytes = (rect.r.w + 7) / 8;
+        int bpp = client->format.bitsPerPixel / 8;
+        uint8_t threshold;
+        char *row_packed = NULL;
+        char *row_expanded = NULL;
+        int row, col, bit, byte;
+        uint8_t set, v;
+        char *dst;
+        uint16_t pix;
+        if (!ReadFromRFBServer(client, (char*)&threshold, 1)) return FALSE;
+        (void)threshold;
+        row_packed = (char*)malloc(row_bytes);
+        row_expanded = (char*)malloc((size_t)rect.r.w * bpp);
+        if (!row_packed || !row_expanded) { free(row_packed); free(row_expanded); return FALSE; }
+        for (row = 0; row < rect.r.h; ++row) {
+          if (!ReadFromRFBServer(client, row_packed, row_bytes)) {
+            free(row_packed); free(row_expanded); return FALSE;
+          }
+          for (col = 0; col < rect.r.w; ++col) {
+            bit = 7 - (col & 7);
+            byte = col >> 3;
+            set = (row_packed[byte] >> bit) & 1;
+            v = set ? 0xFF : 0x00;
+            dst = row_expanded + (size_t)col * bpp;
+            if (bpp == 4) {
+              dst[0] = (char)v; dst[1] = (char)v; dst[2] = (char)v; dst[3] = (char)0xFF;
+            } else if (bpp == 2) {
+              pix = set ? (uint16_t)0xFFFF : (uint16_t)0x0000;
+              memcpy(dst, &pix, 2);
+            } else {
+              memset(dst, (int)v, bpp);
+            }
+          }
+          client->GotBitmap(client, (uint8_t*)row_expanded,
+                           rect.r.x, rect.r.y + row, rect.r.w, 1);
+        }
+        free(row_packed);
+        free(row_expanded);
+        goto rect_done;   /* skip the switch; hit cleanup below */
+      }
+
       switch (rect.encoding) {
 
       case rfbEncodingRaw: {
@@ -2564,6 +2618,7 @@ HandleRFBServerMessage(rfbClient* client)
       }
 
       /* Now we may discard "soft cursor locks". */
+rect_done:
       client->SoftCursorUnlockScreen(client);
 
       client->GotFrameBufferUpdate(client, rect.r.x, rect.r.y, rect.r.w, rect.r.h);
